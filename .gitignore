# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/

# Environments
.env
.venv/

# Generated outputs — track run artifacts, skip binary pickles
outputs/**/gepa_state.bin
outputs/**/*.pkl
outputs/**/*.pickle

# Data
data/train/*
!data/train/.gitkeep
!data/train/*.jsonl
!data/train/*.xlsx
data/test/*
!data/test/.gitkeep
!data/test/*.jsonl
!data/test/*.xlsx
data/validation/*
!data/validation/.gitkeep
!data/validation/*.jsonl
!data/validation/*.xlsx
data/external/*
!data/external/.gitkeep
!data/external/*.jsonl
!data/external/*.xlsx

# Editors and OS
.DS_Store
.idea/
.vscode/
